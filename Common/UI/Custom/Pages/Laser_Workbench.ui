$Common = "../Common.ui";

Group #Root {
  Anchor: (Full: 0);

  Group {
    Anchor: (Full: 0);
    Background: #02060a(0.20);
  }

  Group {
    Anchor: (Top: 0, Left: 0, Right: 0, Height: 170);
    Background: #07111a(0.16);
  }

  Group {
    Anchor: (Bottom: 0, Left: 0, Right: 0, Height: 260);
    Background: #03080e(0.10);
  }

  Group {
    Anchor: (Top: 42, Left: 0, Right: 0, Height: 86);
    LayoutMode: CenterMiddle;

    Group {
      Anchor: (Width: 700, Height: 66);
      Background: #7b8da2(0.34);
      Padding: (Full: 2);

      Group {
        Anchor: (Full: 0);
        Background: #0f1822(0.92);

        Group {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 232);
          Padding: (Top: 6, Left: 6, Bottom: 6, Right: 3);

          $Common.@TextButton #HiltButton { @Text = "HILT"; Anchor: (Full: 0); }

          Group #HiltTabIndicator {
            Visible: false;
            Anchor: (Left: 42, Right: 39, Bottom: 7, Height: 4);
            Background: #8dd8ff;
          }
        }

        Group {
          Anchor: (Left: 232, Top: 14, Width: 1, Height: 38);
          Background: #a8b8ca(0.34);
        }

        Group {
          Anchor: (Left: 233, Top: 0, Bottom: 0, Width: 232);
          Padding: (Top: 6, Left: 3, Bottom: 6, Right: 3);

          $Common.@TextButton #ColorButton { @Text = "COLOR"; Anchor: (Full: 0); }

          Group #ColorTabIndicator {
            Visible: false;
            Anchor: (Left: 39, Right: 39, Bottom: 7, Height: 4);
            Background: #8dd8ff;
          }
        }

        Group {
          Anchor: (Left: 465, Top: 14, Width: 1, Height: 38);
          Background: #a8b8ca(0.34);
        }

        Group {
          Anchor: (Left: 466, Top: 0, Bottom: 0, Width: 232);
          Padding: (Top: 6, Left: 3, Bottom: 6, Right: 6);

          $Common.@TextButton #StanceButton { @Text = "STANCE"; Anchor: (Full: 0); }

          Group #StanceTabIndicator {
            Visible: false;
            Anchor: (Left: 39, Right: 42, Bottom: 7, Height: 4);
            Background: #8dd8ff;
          }
        }
      }
    }
  }

  Group {
    Anchor: (Left: 320, Bottom: 280, Width: 200, Height: 74);

    Background: #7b8da2(0.34);
    Padding: (Full: 2);

    Group {
      Anchor: (Full: 0);
      Background: #15202c(0.92);
      Padding: (Full: 4);

      $Common.@TextButton #PrevElement { @Text = "<"; Anchor: (Full: 0); }
    }
  }

  Group {
    Anchor: (Right: 320, Bottom: 280, Width: 200, Height: 74);
    Background: #7b8da2(0.34);
    Padding: (Full: 2);

    Group {
      Anchor: (Full: 0);
      Background: #15202c(0.92);
      Padding: (Full: 4);

      $Common.@TextButton #NextElement { @Text = ">"; Anchor: (Full: 0); }
    }
  }

  Group {
    Anchor: (Right: 300, Top: 392, Width: 240, Height: 248);
    Background: #6c8098(0.40);
    Padding: (Full: 3);

    Group {
      Anchor: (Full: 0);
      Background: #101820(0.86);
      Padding: (Full: 12);

      Group {
        Anchor: (Left: 0, Right: 0, Top: 8, Height: 34);
        LayoutMode: CenterMiddle;

        Label {
          Text: "Kyber Crystals";
          Style: (FontSize: 26, Alignment: Center);
        }
      }

      Group {
        Anchor: (Top: 58, Left: 0, Right: 0, Height: 98);
        LayoutMode: CenterMiddle;

        ItemGrid #CrystalSlot {
          SlotsPerRow: 1;
          Style: (
            SlotSize: 82,
            SlotIconSize: 76,
            SlotSpacing: 0,
            SlotBackground: "../Common/BlockSelectorSlotBackground.png"
          );
        }
      }

      Group {
        Anchor: (Bottom: 36, Left: 0, Right: 0, Height: 36);
        LayoutMode: CenterMiddle;

        Label #CrystalCountText {
          Text: "Owned: 0";
          Style: (FontSize: 22, Alignment: Center);
        }
      }
    }
  }

  Group {
    Anchor: (Left: 300, Top: 392, Width: 240, Height: 248);
    Background: #6c8098(0.40);
    Padding: (Full: 3);

    Group {
      Anchor: (Full: 0);
      Background: #101820(0.86);
      Padding: (Full: 12);

      Group {
        Anchor: (Left: 0, Right: 0, Top: 8, Height: 34);
        LayoutMode: CenterMiddle;

        Label {
          Text: "Hilt Components";
          Style: (FontSize: 26, Alignment: Center);
        }
      }

      Group {
        Anchor: (Top: 58, Left: 0, Right: 0, Height: 98);
        LayoutMode: CenterMiddle;

        ItemGrid #SaberSlot {
          SlotsPerRow: 1;
          Style: (
            SlotSize: 82,
            SlotIconSize: 76,
            SlotSpacing: 0,
            SlotBackground: "../Common/BlockSelectorSlotBackground.png"
          );
        }
      }

      Group {
        Anchor: (Bottom: 36, Left: 0, Right: 0, Height: 36);
        LayoutMode: CenterMiddle;

        Label #SaberCountText {
          Text: "Owned: 0";
          Style: (FontSize: 22, Alignment: Center);
        }
      }
    }
  }

  Group {
    Anchor: (Bottom: 252, Left: 0, Right: 0, Height: 134);
    LayoutMode: CenterMiddle;

    Group {
      Anchor: (Width: 700, Height: 160);
      Background: #7b8da2(0.32);
      Padding: (Full: 2);

      Group {
        Anchor: (Full: 0);
        Background: #101923(0.84);

        Group {
          Anchor: (Top: 12, Left: 0, Right: 0, Height: 28);
          LayoutMode: CenterMiddle;

          Label #CraftingTitleText {
            Visible: false;
            Text: "Crafting saber...";
            Style: (FontSize: 26, Alignment: Center);
          }
        }

        Group {
          Anchor: (Full: 0);
          LayoutMode: CenterMiddle;

          Label #FooterText {
            Text: "Selected stance: Single";
            Style: (FontSize: 32, Alignment: Center);
          }
        }

        Group #CraftingProgressGroup {
          Visible: false;
          Anchor: (Bottom: 16, Left: 0, Right: 0, Height: 72);

          Group {
            Anchor: (Top: 0, Left: 0, Right: 0, Height: 26);
            LayoutMode: CenterMiddle;

            Label #CraftingProgressText {
              Text: "Crafting... 0%";
              Style: (FontSize: 20, Alignment: Center);
            }
          }

          Group {
            Anchor: (Bottom: 0, Left: 0, Right: 0, Height: 28);
            LayoutMode: CenterMiddle;

            Group {
              Anchor: (Width: 420, Height: 20);
              Background: "../Common/ProgressBar.png";
              Padding: (Full: 4);

              ProgressBar #CraftingProgressBar {
                Value: 0.0;
                BarTexturePath: "../Common/ProgressBarFill.png";
                EffectTexturePath: "../Common/ProgressBarEffect.png";
                EffectWidth: 102;
                EffectHeight: 58;
                EffectOffset: 74;
              }
            }
          }
        }
      }
    }
  }

  Group {
    Anchor: (Bottom: 146, Left: 0, Right: 0, Height: 96);
    LayoutMode: CenterMiddle;

    Group {
      Anchor: (Width: 366, Height: 82);
      Background: #94b7ff(0.50);
      Padding: (Full: 3);

      Group {
        Anchor: (Full: 0);
        Background: #0d2d65(0.72);
        Padding: (Full: 5);

        $Common.@TextButton #FinishCrafting { @Text = "BUILD SABER"; Anchor: (Full: 0); }
      }
    }
  }

  Group {
    Anchor: (Top: 300, Left: 0, Right: 0, Height: 28);
    LayoutMode: CenterMiddle;

    Label #InfoText {
      Text: "";
      Style: (FontSize: 20, Alignment: Center);
    }
  }

}
