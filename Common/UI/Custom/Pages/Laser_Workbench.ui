$Common = "../Common.ui";

Group {
  Anchor: (Full: 0);
  LayoutMode: Full;

  Group {
    Anchor: (Top: 50, Left: 0, Right: 0, Height: 100);
    LayoutMode: CenterMiddle;
    $Common.@TextButton #StanceButton { @Text = "Stance"; Anchor: (Width: 150); Padding: (Right: 10); }
    $Common.@TextButton #ColorButton { @Text = "Color";  Anchor: (Width: 150); Padding: (Right: 10); }
    $Common.@TextButton #HiltButton { @Text = "Hilt";   Anchor: (Width: 150); }
  }

  Group {
    Anchor: (Left: 100, Top: 0, Bottom: 0, Width: 300);
    LayoutMode: CenterMiddle;
    $Common.@TextButton #PrevElement {
      @Text = "Left Option";
      Anchor: (Width: 200, Height: 60);
    }
  }
  Group {
    Anchor: (Full: 0, Right: 500, Top: 100);
    LayoutMode: CenterMiddle;
//    ItemSlot  #SaberSlot {
//      Anchor: (Width: 80, Height: 80);
//    }
    ItemGrid #SaberSlot {
      //Anchor: (Width: 300, Height: 300);
      SlotsPerRow: 1;
      Style: (
        SlotSize: 64,
        SlotIconSize: 64,
        SlotSpacing: 0,
        SlotBackground: "../Common/BlockSelectorSlotBackground.png"
      );
    }
  }
  Group {
    Anchor: (Full: 0, Right: 500, Top: 185);
    LayoutMode: CenterMiddle;
    Label #SaberCountText {
      Text: "Owned: 0";
      Style: (FontSize: 20, Alignment: Center);
    }
  }
  Group {
    Anchor: (Full: 0, Left: 500, Top: 100);
    LayoutMode: CenterMiddle;
//    ItemSlot #CrystalSlot {
//      Anchor: (Width: 80, Height: 80);
//    }
    ItemGrid #CrystalSlot {
      //Anchor: (Width: 300, Height: 300);
      SlotsPerRow: 1;
      Style: (
        SlotSize: 64,
        SlotIconSize: 64,
        SlotSpacing: 0,
        SlotBackground: "../Common/BlockSelectorSlotBackground.png"
      );
    }
  }
  Group {
    Anchor: (Full: 0, Left: 500, Top: 185);
    LayoutMode: CenterMiddle;
    Label #CrystalCountText {
      Text: "Owned: 0";
      Style: (FontSize: 20, Alignment: Center);
    }
  }

  Group {
    Anchor: (Right: 100, Top: 0, Bottom: 0, Width: 300);
    LayoutMode: CenterMiddle;
    $Common.@TextButton #NextElement {
      @Text = "Right Action";
      Anchor: (Width: 200, Height: 60);
    }
  }

  Group {
    Anchor: (Bottom: 300, Left: 0, Right: 0, Height: 100);
    LayoutMode: CenterMiddle;
    Label #FooterText {
      Text: "-----";
      Style: (FontSize: 32, Alignment: Center);
    }
  }
  Group #CraftingProgressGroup {
    Visible: false;
    Anchor: (Bottom: 120, Left: 0, Right: 0, Height: 90);

    Group {
      Anchor: (Top: 0, Left: 0, Right: 0, Height: 30);
      LayoutMode: CenterMiddle;
      Label #CraftingProgressText {
        Text: "Crafting... 0%";
        Style: (FontSize: 22, Alignment: Center);
      }
    }

    Group {
      Anchor: (Bottom: 0, Left: 0, Right: 0, Height: 28);
      LayoutMode: CenterMiddle;

      Group {
        Anchor: (Width: 360, Height: 20);
        Background: "../Common/ProgressBar.png";
        Padding: (Full: 4);

        ProgressBar #CraftingProgressBar {
          Value: 0.0;
          BarTexturePath: "../Common/ProgressBarFill.png";
          EffectTexturePath: "../Common/ProgressBarEffect.png";
          EffectWidth: 102;
          EffectHeight: 58;
          EffectOffset: 74;
        }
      }
    }
  }
  Group {
    Anchor: (Bottom: 165, Left: 0, Right: 0, Height: 28);
    LayoutMode: CenterMiddle;
    Label #InfoText {
      Text: "";
      Style: (FontSize: 20, Alignment: Center);
    }
  }
  Group {
    Anchor: (Bottom: 200, Left: 0, Right: 0, Height: 100);
    LayoutMode: CenterMiddle;
    $Common.@TextButton #FinishCrafting { @Text = "Build saber";   Anchor: (Width: 200, Height: 60); }
  }
}
