$Common = "../Common.ui";

Group {
    Anchor: (Height: 150, Left: 10, Right: 10, Bottom: 10);
    LayoutMode: Left;
    Padding: (Full: 15);
    Background: #000000(0.6); // Semi-transparent black background [9]

    // Big Avatar Icon
    Group #Avatar {
        Anchor: (Width: 120, Height: 120);
        Background: (TexturePath: "galaxy.png");
    }

    // Text Information Column
    Group #Container {
        FlexWeight: 1; // Takes up remaining horizontal space [11]
        LayoutMode: Top;
        Padding: (Left: 20);

        Label #TargetName {
            Text: "Name";
            Style: (FontSize: 32);
        }
        Label #PlanetName {
            Text: "Planet";
            Style: (FontSize: 22, TextColor: #AAAAAA);
        }
        Label #Coordinates {
            Text: "0, 0, 0";
            Style: (FontSize: 18, FontName: "Mono"); // Mono font for coordinates [12]
        }
    }

    // Reward Column
    Group #Reward {
        Anchor: (Width: 220);
        LayoutMode: CenterMiddle;

        Group {
            Anchor: (Width: 180, Height: 36);
            LayoutMode: Left;

            Label #RewardLabel {
                Anchor: (Width: 90, Height: 30);
                Text: "Reward";
                Style: (FontSize: 22, TextColor: #AAAAAA);
            }

            ItemSlot #GoldSlot {
                Anchor: (Width: 36, Height: 36);
                ItemId: "OrbisGalactic_Galactic_Credit_Gold";
                Quantity: 0;
                ShowQuantity: true;
            }

            Group {
                Anchor: (Width: 8, Height: 36);
            }

            ItemSlot #SilverSlot {
                Anchor: (Width: 36, Height: 36);
                ItemId: "OrbisGalactic_Galactic_Credit_Silver";
                Quantity: 0;
                ShowQuantity: true;
            }
        }
    }

    Group #ActionColumn {
        Anchor: (Width: 160);
        LayoutMode: CenterMiddle;
        $Common.@TextButton #AcceptButton {
            @Text = "Accept";
            Anchor: (Width: 130, Height: 50);
        }
    }
}
