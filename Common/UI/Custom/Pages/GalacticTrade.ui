  $C = "../Common.ui";

  $C.@PageOverlay {}

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 920, Height: 700);

    #Title {
      Group {
        LayoutMode: Left;

        $C.@Title {
          @Text = "Galactic Market";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 12, Top: 10, Bottom: 14);

      Group #Toolbar {
        Anchor: (Height: 48);
        LayoutMode: Left;
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
        Padding: (Horizontal: 14, Vertical: 10);

        $C.@TextField #SearchInput {
          @Anchor = (Width: 260, Right: 12);
          PlaceholderText: "Search market";
        }

        Label #ResultSummary {
          FlexWeight: 1;
          Style: (
            FontSize: 17,
            RenderBold: true,
            TextColor: #d6d8db,
            VerticalAlignment: Center
          );
          Text: "";
        }

        Group {
          Anchor: (Width: 14);
        }

        Group #WalletInfo {
          Anchor: (Width: 212, Height: 28);
          LayoutMode: Left;

          Label {
            Anchor: (Width: 46);
            Style: (
              FontSize: 13,
              TextColor: #c8d7e4,
              VerticalAlignment: Center
            );
            Text: "Wallet";
          }

          Group {
            Anchor: (Width: 10);
          }

          ItemIcon #WalletGoldIcon {
            Anchor: (Width: 20, Height: 20, Vertical: 0.5);
          }

          Label #WalletGoldCount {
            Anchor: (Width: 40);
            TooltipText: "";
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            TextTooltipShowDelay: 0.1;
            Style: (
              FontSize: 13,
              TextColor: #c8d7e4,
              VerticalAlignment: Center,
              HorizontalAlignment: Start
            );
            Text: "0";
          }

          ItemIcon #WalletSilverIcon {
            Anchor: (Left: 6, Width: 20, Height: 20, Vertical: 0.5);
          }

          Label #WalletSilverCount {
            Anchor: (Width: 40);
            TooltipText: "";
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            TextTooltipShowDelay: 0.1;
            Style: (
              FontSize: 13,
              TextColor: #c8d7e4,
              VerticalAlignment: Center,
              HorizontalAlignment: Start
            );
            Text: "0";
          }
        }

        Label #RefreshInfo {
          Anchor: (Width: 220);
          Style: (
            FontSize: 13,
            TextColor: #9aafbf,
            VerticalAlignment: Center,
            HorizontalAlignment: End
          );
          Text: "";
        }

      }

      Group #GridFrame {
        FlexWeight: 1;
        Anchor: (Top: 12);
        Background: (TexturePath: "../Common/ContainerPatch.png", Border: 23);
        Padding: (Full: 12);
        LayoutMode: Top;

        Group #OfferGridScroller {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);

          Group #OfferGrid {
            LayoutMode: LeftCenterWrap;
          }
        }

        Group #EmptyState {
          Visible: false;
          LayoutMode: Top;
          Anchor: (Full: 0);

          Group {
            Anchor: (Top: 28, Width: 380, Height: 160, Horizontal: 0);
            Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
            LayoutMode: CenterMiddle;
            Padding: (Horizontal: 20);

            Label {
              Text: "No market offers match your search.";
              Style: (
                FontSize: 18,
                RenderBold: true,
                TextColor: #c5ccd5,
                HorizontalAlignment: Center,
                VerticalAlignment: Center,
                Wrap: true
              );
            }
          }
        }
      }
    }
  }
