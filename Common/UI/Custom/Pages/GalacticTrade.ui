$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  @CloseButton = true;
  Anchor: (Width: 980, Height: 720);

  #Title {
    Group {
      LayoutMode: Left;

      $C.@Title {
        @Text = "Galactic Market";
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Horizontal: 12, Top: 10, Bottom: 14);

    Group #Toolbar {
      Anchor: (Height: 48);
      LayoutMode: Left;
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
      Padding: (Horizontal: 14, Vertical: 10);

      $C.@TextField #SearchInput {
        @Anchor = (Width: 260, Right: 12);
        PlaceholderText: "Search market";
      }

      Label #ResultSummary {
        FlexWeight: 1;
        Style: (
          FontSize: 17,
          RenderBold: true,
          TextColor: #d6d8db,
          VerticalAlignment: Center
        );
        Text: "";
      }

      Label #RefreshInfo {
        Anchor: (Width: 320);
        Style: (
          FontSize: 13,
          TextColor: #9aafbf,
          VerticalAlignment: Center,
          HorizontalAlignment: End
        );
        Text: "";
      }

      Group {
        Anchor: (Width: 12);
      }

      $C.@SecondaryTextButton #BtnRefresh {
        Text: "Refresh";
        Anchor: (Width: 132);
      }
    }

    Group #GridFrame {
      FlexWeight: 1;
      Anchor: (Top: 12);
      Background: (TexturePath: "../Common/ContainerPatch.png", Border: 23);
      Padding: (Full: 12);
      LayoutMode: Top;

      Group #OfferGridScroller {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Right: 6);

        Group #OfferGrid {
          LayoutMode: LeftCenterWrap;
        }
      }

      Group #EmptyState {
        Visible: false;
        LayoutMode: CenterMiddle;
        Anchor: (Full: 0);

        Group {
          Anchor: (Width: 380, Height: 160);
          Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
          LayoutMode: CenterMiddle;
          Padding: (Horizontal: 20);

          Label {
            Text: "No market offers match your search.";
            Style: (
              FontSize: 18,
              RenderBold: true,
              TextColor: #c5ccd5,
              HorizontalAlignment: Center,
              VerticalAlignment: Center,
              Wrap: true
            );
          }
        }
      }
    }
  }
}
