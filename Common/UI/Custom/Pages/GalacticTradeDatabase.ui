  $C = "../Common.ui";

  $C.@PageOverlay {}

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 920, Height: 700);

    #Title {
      Group {
        LayoutMode: Left;

        $C.@Title {
          @Text = "Price History";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 12, Top: 10, Bottom: 14);

      Group #Toolbar {
        Anchor: (Height: 48);
        LayoutMode: Left;
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
        Padding: (Horizontal: 14, Vertical: 10);

        $C.@SecondaryTextButton #BtnBackToMarket {
          Text: "Back";
          Anchor: (Width: 120);
        }

        Group {
          Anchor: (Width: 14);
        }

        $C.@TextField #DatabaseSearchInput {
          @Anchor = (Width: 260, Right: 12);
          PlaceholderText: "Search price history";
        }

        Label #DatabaseSummary {
          FlexWeight: 1;
          Style: (
            FontSize: 17,
            RenderBold: true,
            TextColor: #d6d8db,
            VerticalAlignment: Center
          );
          Text: "";
        }

        Label #RefreshInfo {
          Anchor: (Width: 220);
          Style: (
            FontSize: 13,
            TextColor: #9aafbf,
            VerticalAlignment: Center,
            HorizontalAlignment: End
          );
          Text: "";
        }

        Group #WalletInfo {
          Visible: false;
          Anchor: (Width: 1, Height: 1);
          LayoutMode: Left;

          ItemIcon #WalletGoldIcon {
            Anchor: (Width: 1, Height: 1);
          }

          Label #WalletGoldCount {
            Anchor: (Width: 1, Height: 1);
            TooltipText: "";
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            TextTooltipShowDelay: 0.1;
            Text: "0";
          }

          ItemIcon #WalletSilverIcon {
            Anchor: (Width: 1, Height: 1);
          }

          Label #WalletSilverCount {
            Anchor: (Width: 1, Height: 1);
            TooltipText: "";
            TextTooltipStyle: $C.@DefaultTextTooltipStyle;
            TextTooltipShowDelay: 0.1;
            Text: "0";
          }
        }
      }

      Group #MarketEventPopup {
        Visible: false;
        Anchor: (Top: 10, Height: 74);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
        Padding: (Horizontal: 16, Vertical: 10);
        LayoutMode: Top;

        Label {
          Anchor: (Height: 14);
          Text: "MARKET EVENT";
          Style: (
            FontSize: 11,
            RenderBold: true,
            RenderUppercase: true,
            TextColor: #d9a86c
          );
        }

        Group {
          Anchor: (Top: 2, Height: 22);
          LayoutMode: Left;

          Label #MarketEventTitle {
            FlexWeight: 1;
            Style: (
              FontSize: 18,
              RenderBold: true,
              TextColor: #e5eaef,
              VerticalAlignment: Center
            );
            Text: "";
          }

          Label #MarketEventTimer {
            Anchor: (Width: 90);
            Style: (
              FontSize: 12,
              TextColor: #d9a86c,
              HorizontalAlignment: End,
              VerticalAlignment: Center
            );
            Text: "";
          }
        }

        Label #MarketEventDescription {
          Anchor: (Top: 4, Height: 18);
          Style: (
            FontSize: 13,
            TextColor: #b8c5d1,
            Wrap: true
          );
          Text: "";
        }
      }

      Group #DatabaseFrame {
        FlexWeight: 1;
        Anchor: (Top: 12);
        Background: (TexturePath: "../Common/ContainerPatch.png", Border: 23);
        Padding: (Full: 12);
        LayoutMode: Top;

        Group #DatabaseResultScroller {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);

          Group #DatabaseResultList {
            LayoutMode: Top;
          }
        }

        Group #DatabaseLoadingState {
          Visible: false;
          LayoutMode: Top;
          Anchor: (Full: 0);

          Group {
            Anchor: (Top: 28, Width: 420, Height: 160, Horizontal: 0);
            Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
            LayoutMode: CenterMiddle;
            Padding: (Horizontal: 20);

            Label #DatabaseLoadingText {
              Text: "";
              Style: (
                FontSize: 18,
                RenderBold: true,
                TextColor: #c5ccd5,
                HorizontalAlignment: Center,
                VerticalAlignment: Center,
                Wrap: true
              );
            }
          }
        }

        Group #DatabaseEmptyState {
          Visible: false;
          LayoutMode: Top;
          Anchor: (Full: 0);

          Group {
            Anchor: (Top: 28, Width: 420, Height: 160, Horizontal: 0);
            Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);
            LayoutMode: CenterMiddle;
            Padding: (Horizontal: 20);

            Label #DatabaseEmptyText {
              Text: "";
              Style: (
                FontSize: 18,
                RenderBold: true,
                TextColor: #c5ccd5,
                HorizontalAlignment: Center,
                VerticalAlignment: Center,
                Wrap: true
              );
            }
          }
        }
      }
    }
  }
